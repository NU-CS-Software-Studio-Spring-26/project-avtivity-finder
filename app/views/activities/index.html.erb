<% content_for :title, "Activities" %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="mb-0">Activities</h1>
  <div class="d-flex gap-2">
    <%= link_to "New Activity", new_activity_path, class: "btn btn-primary" %>
  </div>
</div>

<div class="activity-grid">
  <% @activities.each do |activity| %>
    <div class="activity-card">
      <div class="activity-card-img">
        <%= image_tag activity_image(activity), class: "img-fluid" %>
      </div>

        <div class="activity-card-body">
          <div class="d-flex flex-wrap gap-2 mb-2">
            <% if @joined_activity_ids.include?(activity.id) %>
              <span class="badge text-bg-success">You’re going</span>
            <% end %>

            <% taken = @signup_counts[activity.id] || 0 %>
            <% if activity.capacity.present? %>
              <% full = taken >= activity.capacity %>
              <span class="badge <%= full ? "text-bg-warning" : "text-bg-light border" %>">
                <%= taken %>/<%= activity.capacity %> spots<%= full ? " (full)" : "" %>
              </span>
            <% else %>
              <span class="badge text-bg-light border"><%= taken %> going</span>
            <% end %>
          </div>

          <h5 class="activity-title">
            <%= link_to activity.title, activity %>
          </h5>

        <p class="activity-meta">
          <%= activity.city %>
          <% if activity.event_date.present? %>
            • <%= activity.event_date.strftime("%b %d") %>
          <% end %>
        </p>

        <p class="activity-category">
          <%= activity.category %>
        </p>
      </div>
    </div>
  <% end %>
</div>
