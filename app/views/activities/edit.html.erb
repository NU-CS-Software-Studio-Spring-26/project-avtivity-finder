<% content_for :title, "Editing activity" %>

<div class="surface-card">
  <div class="surface-card-header">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
      <div>
        <h1 class="h3 mb-1">Edit activity</h1>
        <div class="text-muted">Update details, manage images, and keep your attendees informed.</div>
      </div>
      <div class="d-flex gap-2">
        <%= link_to "View", @activity, class: "btn btn-outline-secondary btn-sm" %>
        <%= link_to "Back", activities_path, class: "btn btn-outline-secondary btn-sm" %>
      </div>
    </div>
  </div>

  <div class="surface-card-body">
    <%= render "form", activity: @activity %>
  </div>
</div>
