<% content_for :title, "Login" %>

<div class="auth-container">
  <div class="auth-card">
    <h1 class="auth-title mb-1">Welcome back</h1>
    <p class="text-muted text-center mb-4">Log in to create activities and RSVP.</p>

    <%= form_with url: login_path, method: :post do %>
      <div class="mb-3">
        <%= label_tag :email, "Email", class: "form-label" %>
        <%= email_field_tag :email, nil, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= label_tag :password, "Password", class: "form-label" %>
        <%= password_field_tag :password, nil, class: "form-control" %>
      </div>

      <%= submit_tag "Login", class: "btn btn-primary btn-auth" %>
    <% end %>

    <div class="auth-links">
      Don't have an account?
      <%= link_to "Sign up", signup_path %>
    </div>
  </div>
</div>